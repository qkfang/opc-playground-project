{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/js/*", "/favicon.ico", "/*.svg", "/*.png", "/*.ico", "/*.txt", "/*.css", "/*.js"]
  },
  "responseOverrides": {
    "404": { "rewrite": "/index.html" }
  },
  "mimeTypes": {
    ".js": "text/javascript",
    ".svg": "image/svg+xml"
  }
}
