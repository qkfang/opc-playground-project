@page "/platform/operations"
@model Proj37.CostEstimator.Web.Pages.Platform.OperationsModel
@{
    ViewData["Title"] = "Operation Cost";
    ViewData["ActivePage"] = "operations";
}

<section class="card platform-head">
    <div class="result-head">
        <div>
            <h2>Operation Cost</h2>
            <p class="hint" id="ctxLine">No estimation loaded yet.</p>
        </div>
        <div class="result-actions">
            <button type="button" class="btn btn-secondary" data-agent-step="operations">ℹ Agent instructions</button>
            <a id="downloadBtn" class="btn btn-download" href="#" hidden>⬇ Download Excel</a>
        </div>
    </div>
</section>

<section class="card" id="emptyState">
    <p class="muted">No estimation has been run yet. <a href="/">Upload a document or run an example brief</a> to populate Build vs Buy Agent.</p>
</section>

<section class="card" id="operationsCard" hidden>
    <p class="hint">Ongoing monthly cost to run, support, and maintain the solution after go-live (excludes Azure infrastructure). The <strong>Qty</strong> and <strong>Unit price</strong> columns are editable — change a value to recalculate the monthly run total live. The downloaded Excel workbook keeps these editable on an <strong>Operation Cost</strong> sheet.</p>
    <div class="totals" id="operationsTotals"></div>
    <div id="tab-operations"></div>
</section>
