@page
@model Proj37.CostEstimator.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Upload";
    ViewData["ActivePage"] = "upload";
}

<section class="card upload-card">
    <h2>Upload technical documents</h2>
    <p class="hint">Supported: .md .txt .json .csv .docx and more. Or open one of the example briefs below and run it.</p>
    <form id="uploadForm">
        <label class="dropzone" id="dropzone">
            <input type="file" id="fileInput" name="files" multiple
                   accept=".md,.markdown,.txt,.json,.csv,.tsv,.log,.yaml,.yml,.xml,.html,.htm,.docx" />
            <span id="dropLabel">Click to choose files or drag &amp; drop</span>
        </label>
        <div id="fileList" class="file-list"></div>
        <div class="actions">
            <button type="submit" id="estimateBtn" class="btn btn-primary">Estimate cost</button>
        </div>
    </form>
    <div id="status" class="status" hidden></div>
</section>

<section class="card samples-card">
    <h2>Example requirement documents</h2>
    <p class="hint">Click <strong>View</strong> to read a sample brief in a popup, or <strong>Use this</strong> to run the full estimation pipeline against it.</p>
    <div id="sampleList" class="sample-list">Loading examples…</div>
</section>

<section class="card next-card" id="doneCard" hidden>
    <h2>✓ Estimation ready</h2>
    <p class="hint" id="doneSummary"></p>
    <div class="actions">
        <a class="btn btn-primary" href="/platform/scope">Open Build vs Buy Agent →</a>
        <a class="btn btn-secondary" href="/estimations">View recent estimations</a>
        <a id="doneDownload" class="btn btn-download" href="#">⬇ Download Excel</a>
    </div>
</section>
