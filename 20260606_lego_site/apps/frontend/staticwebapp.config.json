{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/_next/*", "/favicon.ico", "/*.{svg,png,txt}"]
  },
  "routes": [
    { "route": "/sets/*", "rewrite": "/sets/_/index.html" },
    { "route": "/marketplace/*", "rewrite": "/marketplace/_/index.html" }
  ],
  "responseOverrides": {
    "404": { "rewrite": "/404.html" }
  }
}
