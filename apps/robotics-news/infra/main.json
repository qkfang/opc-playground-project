{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "13858946837361573059"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure location for the App Service plan and Web App."
      }
    },
    "staticWebAppLocation": {
      "type": "string",
      "defaultValue": "East US 2",
      "allowedValues": [
        "Central US",
        "East US 2",
        "West Europe"
      ],
      "metadata": {
        "description": "Azure region for the Static Web App."
      }
    },
    "appServicePlanName": {
      "type": "string",
      "defaultValue": "plan-robotics-news-01",
      "metadata": {
        "description": "Name of the App Service plan."
      }
    },
    "webAppName": {
      "type": "string",
      "defaultValue": "app-robotics-news-api-01",
      "metadata": {
        "description": "Name of the Azure Web App that hosts the API."
      }
    },
    "staticWebAppName": {
      "type": "string",
      "defaultValue": "swa-robotics-news-01",
      "metadata": {
        "description": "Name of the Azure Static Web App that hosts the frontend."
      }
    },
    "appServicePlanSku": {
      "type": "string",
      "defaultValue": "B1",
      "allowedValues": [
        "B1",
        "S1"
      ],
      "metadata": {
        "description": "SKU for the App Service plan."
      }
    },
    "corsAllowedOrigins": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "Allowed frontend origins for the API CORS policy."
      }
    },
    "rssFeedUrls": {
      "type": "array",
      "defaultValue": [
        "https://www.therobotreport.com/feed/",
        "https://roboticsandautomationnews.com/feed/"
      ],
      "metadata": {
        "description": "Robotics RSS feeds consumed by the API."
      }
    }
  },
  "variables": {
    "copy": [
      {
        "name": "corsAppSettings",
        "count": "[length(parameters('corsAllowedOrigins'))]",
        "input": {
          "name": "[format('Cors__AllowedOrigins__{0}', copyIndex('corsAppSettings'))]",
          "value": "[string(parameters('corsAllowedOrigins')[copyIndex('corsAppSettings')])]"
        }
      },
      {
        "name": "rssFeedAppSettings",
        "count": "[length(parameters('rssFeedUrls'))]",
        "input": {
          "name": "[format('NewsFeeds__FeedUrls__{0}', copyIndex('rssFeedAppSettings'))]",
          "value": "[string(parameters('rssFeedUrls')[copyIndex('rssFeedAppSettings')])]"
        }
      }
    ],
    "appServicePlanTier": "[if(equals(parameters('appServicePlanSku'), 'S1'), 'Standard', 'Basic')]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2024-04-01",
      "name": "[parameters('appServicePlanName')]",
      "location": "[parameters('location')]",
      "kind": "linux",
      "sku": {
        "name": "[parameters('appServicePlanSku')]",
        "tier": "[variables('appServicePlanTier')]",
        "capacity": 1
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2024-04-01",
      "name": "[parameters('webAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "DOTNETCORE|10.0",
          "appSettings": "[concat(variables('corsAppSettings'), variables('rssFeedAppSettings'), createArray(createObject('name', 'NewsFeeds__CacheDurationMinutes', 'value', '5')))]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/staticSites",
      "apiVersion": "2024-04-01",
      "name": "[parameters('staticWebAppName')]",
      "location": "[parameters('staticWebAppLocation')]",
      "sku": {
        "name": "Free",
        "tier": "Free"
      },
      "properties": {
        "allowConfigFileUpdates": true,
        "stagingEnvironmentPolicy": "Enabled"
      }
    }
  ],
  "outputs": {
    "apiUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', parameters('webAppName')), '2024-04-01').defaultHostName)]"
    },
    "staticWebAppDefaultHostName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/staticSites', parameters('staticWebAppName')), '2024-04-01').defaultHostname]"
    }
  }
}