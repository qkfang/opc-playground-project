@page
@model IndexModel
@{
    ViewData["Title"] = "Inbox";
}

<div class="app-grid">
    <!-- LEFT: inbox tray -->
    <section class="inbox" aria-label="Inbox tray">
        <div class="inbox-head">
            <h2>Inbox</h2>
            <button id="composeBtn" class="btn-ghost" title="Compose an ad-hoc email + document">+ Compose</button>
        </div>
        <div id="inboxList" class="inbox-list">Loading…</div>
        <div class="inbox-foot">
            <a href="#" id="casesLink">Recent cases →</a>
        </div>
    </section>

    <!-- RIGHT: reader + pipeline -->
    <section class="reader" aria-label="Reader">
        <div id="emptyState" class="empty">
            <div class="empty-icon">◆</div>
            <p>Select a message from the inbox to read the customer email and its document.</p>
            <p class="muted">Then run the Intelligence &amp; Research pipeline: entities → insights → source pulls → research brief → report email.</p>
        </div>

        <div id="readerBody" class="reader-body" hidden>
            <!-- Email + document header -->
            <div class="mail">
                <div class="mail-subject" id="mSubject"></div>
                <div class="mail-meta" id="mMeta"></div>
                <div class="mail-doc" id="mDoc"></div>
                <details class="mail-bodywrap"><summary>Email body &amp; document</summary>
                    <pre class="mail-body" id="mBody"></pre>
                    <pre class="mail-document" id="mDocBody"></pre>
                </details>
                <div class="run-row">
                    <button id="runBtn" class="btn-primary">▶ Run intelligence &amp; research pipeline</button>
                    <span id="runStatus" class="run-status"></span>
                </div>
            </div>

            <!-- Pipeline stage tabs -->
            <div id="resultWrap" hidden>
                <nav class="tabs" role="tablist">
                    <button class="tab active" data-tab="entities" role="tab">1 · Entities</button>
                    <button class="tab" data-tab="insights" role="tab">2 · Insights</button>
                    <button class="tab" data-tab="sources" role="tab">3 · Sources</button>
                    <button class="tab" data-tab="research" role="tab">4 · Research brief</button>
                    <button class="tab" data-tab="report" role="tab">5 · Report email</button>
                </nav>
                <div class="tabpanes">
                    <div class="pane tabpane active" id="tab-entities"></div>
                    <div class="pane tabpane" id="tab-insights"></div>
                    <div class="pane tabpane" id="tab-sources"></div>
                    <div class="pane tabpane" id="tab-research"></div>
                    <div class="pane tabpane" id="tab-report"></div>
                </div>
                <div class="agent-trace" id="agentTrace"></div>
            </div>
        </div>
    </section>
</div>

<!-- Compose modal -->
<div id="composeModal" class="modal" hidden>
    <div class="modal-card">
        <div class="modal-head"><h3>Compose ad-hoc email + document</h3><button id="composeClose" class="btn-ghost">✕</button></div>
        <div class="modal-body">
            <label>From name<input id="cFromName" placeholder="Jane Doe" /></label>
            <label>From email<input id="cFrom" placeholder="jane@acme.com" /></label>
            <label>Subject<input id="cSubject" placeholder="RFP attached — analytics platform" /></label>
            <label>Email body<textarea id="cBody" rows="3" placeholder="Short covering note…"></textarea></label>
            <label>Document type<input id="cDocType" placeholder="RFP / Briefing note / Incident report" /></label>
            <label>Document content<textarea id="cDocBody" rows="8" placeholder="Paste the customer document text here…"></textarea></label>
        </div>
        <div class="modal-foot">
            <button id="composeRun" class="btn-primary">▶ Run pipeline</button>
            <span id="composeStatus" class="run-status"></span>
        </div>
    </div>
</div>

<!-- Cases modal -->
<div id="casesModal" class="modal" hidden>
    <div class="modal-card">
        <div class="modal-head"><h3>Recent cases</h3><button id="casesClose" class="btn-ghost">✕</button></div>
        <div class="modal-body" id="casesList">Loading…</div>
    </div>
</div>

@section Scripts {
    <script src="~/js/app.js" asp-append-version="true"></script>
}
