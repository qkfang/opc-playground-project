{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "1619520107136401366"
    }
  },
  "parameters": {
    "projectId": {
      "type": "string",
      "defaultValue": "20260606-fruit-robotics-news"
    },
    "apiLocation": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "staticWebAppLocation": {
      "type": "string",
      "defaultValue": "eastasia"
    },
    "appServicePlanSkuName": {
      "type": "string",
      "defaultValue": "B1"
    },
    "appServicePlanSkuTier": {
      "type": "string",
      "defaultValue": "Basic"
    },
    "linuxFxVersion": {
      "type": "string",
      "defaultValue": "DOTNETCORE|8.0"
    },
    "newsFeedUrl": {
      "type": "string",
      "defaultValue": "https://news.google.com/rss/search?q=robotics&hl=en-US&gl=US&ceid=US:en"
    }
  },
  "variables": {
    "suffix": "[toLower(uniqueString(subscription().subscriptionId, resourceGroup().id, parameters('projectId')))]",
    "appServicePlanName": "[format('plan-fruit-news-{0}', variables('suffix'))]",
    "apiWebAppName": "[format('api-fruit-news-{0}', variables('suffix'))]",
    "staticWebAppName": "[format('swa-fruit-news-{0}', variables('suffix'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[variables('appServicePlanName')]",
      "location": "[parameters('apiLocation')]",
      "kind": "linux",
      "sku": {
        "name": "[parameters('appServicePlanSkuName')]",
        "tier": "[parameters('appServicePlanSkuTier')]",
        "capacity": 1
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[variables('apiWebAppName')]",
      "location": "[parameters('apiLocation')]",
      "kind": "app,linux",
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "[parameters('linuxFxVersion')]",
          "minTlsVersion": "1.2",
          "appSettings": [
            {
              "name": "NEWS_FEED_URL",
              "value": "[parameters('newsFeedUrl')]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/staticSites",
      "apiVersion": "2023-12-01",
      "name": "[variables('staticWebAppName')]",
      "location": "[parameters('staticWebAppLocation')]",
      "sku": {
        "name": "Free",
        "tier": "Free"
      }
    }
  ],
  "outputs": {
    "apiHostname": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', variables('apiWebAppName')), '2023-12-01').defaultHostName]"
    },
    "apiUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', variables('apiWebAppName')), '2023-12-01').defaultHostName)]"
    },
    "staticWebAppName": {
      "type": "string",
      "value": "[variables('staticWebAppName')]"
    }
  }
}